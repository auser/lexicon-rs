---
/**
 * Progressive scope diagram.
 * Concentric nested rounded rectangles showing additive layers:
 * Inner: Repo Mode, Middle: Workspace Mode, Outer: Ecosystem Mode
 */
---

<figure class="diagram-wrapper" aria-label="Progressive Scope">
  <svg viewBox="0 0 760 380" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Progressive scope: Repo Mode as the core, Workspace Mode adds architecture and shared contracts, Ecosystem Mode adds cross-repo governance">
    <defs>
      <linearGradient id="ps-eco-grad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="var(--diagram-accent)" stop-opacity="0.08" />
        <stop offset="100%" stop-color="var(--diagram-accent)" stop-opacity="0.02" />
      </linearGradient>
      <linearGradient id="ps-ws-grad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="var(--diagram-secondary)" stop-opacity="0.10" />
        <stop offset="100%" stop-color="var(--diagram-secondary)" stop-opacity="0.03" />
      </linearGradient>
      <linearGradient id="ps-repo-grad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="var(--diagram-primary)" stop-opacity="0.15" />
        <stop offset="100%" stop-color="var(--diagram-primary)" stop-opacity="0.04" />
      </linearGradient>
      <filter id="ps-shadow" x="-2%" y="-2%" width="104%" height="104%">
        <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-color="var(--diagram-text)" flood-opacity="0.04" />
      </filter>
    </defs>

    <!-- Ecosystem ring (outer) -->
    <rect x="16" y="16" width="728" height="348" rx="22" fill="url(#ps-eco-grad)" stroke="var(--diagram-accent)" stroke-width="1.5" stroke-opacity="0.35" />
    <text x="380" y="44" text-anchor="middle" class="ps-ring-label" fill="var(--diagram-accent)">ECOSYSTEM MODE</text>

    <!-- Ecosystem features (left column) -->
    <g class="ps-features-eco">
      <text x="46" y="82" class="ps-feature-title" fill="var(--diagram-accent)">+ adds:</text>
      <text x="46" y="102" class="ps-feature" fill="var(--diagram-text-muted)">repo roles &amp; owners</text>
      <text x="46" y="120" class="ps-feature" fill="var(--diagram-text-muted)">federated contracts</text>
      <text x="46" y="138" class="ps-feature" fill="var(--diagram-text-muted)">cross-repo governance</text>
      <text x="46" y="156" class="ps-feature" fill="var(--diagram-text-muted)">compatibility checks</text>
      <text x="46" y="174" class="ps-feature" fill="var(--diagram-text-muted)">impact analysis</text>
    </g>

    <!-- Workspace ring (middle) -->
    <rect x="186" y="66" width="558" height="280" rx="18" fill="url(#ps-ws-grad)" stroke="var(--diagram-secondary)" stroke-width="1.5" stroke-opacity="0.35" />
    <text x="465" y="92" text-anchor="middle" class="ps-ring-label" fill="var(--diagram-secondary)">WORKSPACE MODE</text>

    <!-- Workspace features (right column) -->
    <g class="ps-features-ws">
      <text x="560" y="120" class="ps-feature-title" fill="var(--diagram-secondary)">+ adds:</text>
      <text x="560" y="140" class="ps-feature" fill="var(--diagram-text-muted)">architecture graph</text>
      <text x="560" y="158" class="ps-feature" fill="var(--diagram-text-muted)">dependency law</text>
      <text x="560" y="176" class="ps-feature" fill="var(--diagram-text-muted)">crate roles</text>
      <text x="560" y="194" class="ps-feature" fill="var(--diagram-text-muted)">shared contracts</text>
    </g>

    <!-- Repo ring (inner) -->
    <rect x="216" y="114" width="320" height="214" rx="14" fill="url(#ps-repo-grad)" stroke="var(--diagram-primary)" stroke-width="2" stroke-opacity="0.45" />
    <text x="376" y="138" text-anchor="middle" class="ps-ring-label" fill="var(--diagram-primary)">REPO MODE</text>

    <!-- Repo feature chips -->
    <g class="ps-repo-chips">
      <rect x="236" y="152" width="110" height="34" rx="8" class="ps-chip" filter="url(#ps-shadow)" />
      <text x="291" y="173" text-anchor="middle" class="ps-chip-label" fill="var(--diagram-text)">Contracts</text>

      <rect x="356" y="152" width="130" height="34" rx="8" class="ps-chip" filter="url(#ps-shadow)" />
      <text x="421" y="173" text-anchor="middle" class="ps-chip-label" fill="var(--diagram-text)">Conformance</text>

      <rect x="236" y="196" width="100" height="34" rx="8" class="ps-chip" filter="url(#ps-shadow)" />
      <text x="286" y="217" text-anchor="middle" class="ps-chip-label" fill="var(--diagram-text)">Scoring</text>

      <rect x="346" y="196" width="80" height="34" rx="8" class="ps-chip" filter="url(#ps-shadow)" />
      <text x="386" y="217" text-anchor="middle" class="ps-chip-label" fill="var(--diagram-text)">Gates</text>

      <rect x="436" y="196" width="80" height="34" rx="8" class="ps-chip" filter="url(#ps-shadow)" />
      <text x="476" y="217" text-anchor="middle" class="ps-chip-label" fill="var(--diagram-text)">API</text>

      <rect x="236" y="240" width="100" height="34" rx="8" class="ps-chip" filter="url(#ps-shadow)" />
      <text x="286" y="261" text-anchor="middle" class="ps-chip-label" fill="var(--diagram-text)">Coverage</text>

      <rect x="346" y="240" width="120" height="34" rx="8" class="ps-chip" filter="url(#ps-shadow)" />
      <text x="406" y="261" text-anchor="middle" class="ps-chip-label" fill="var(--diagram-text)">AI Context</text>

      <rect x="236" y="284" width="90" height="34" rx="8" class="ps-chip" filter="url(#ps-shadow)" />
      <text x="281" y="305" text-anchor="middle" class="ps-chip-label" fill="var(--diagram-text)">Doctor</text>
    </g>
  </svg>
</figure>

<style>
  .diagram-wrapper {
    margin: 2rem 0;
    padding: 0;
  }
  .diagram-wrapper svg {
    width: 100%;
    max-width: 760px;
    height: auto;
    margin: 0 auto;
    display: block;
    --diagram-bg: #f8f9fa;
    --diagram-text: #2d3748;
    --diagram-text-muted: #718096;
    --diagram-primary: #4a90d9;
    --diagram-secondary: #48bb78;
    --diagram-accent: #ed8936;
    --diagram-danger: #e53e3e;
    --diagram-border: #cbd5e1;
    --diagram-fill: #ffffff;
  }
  :global([data-theme='dark']) .diagram-wrapper svg,
  :global(.sl-theme-dark) .diagram-wrapper svg {
    --diagram-bg: #1a1b26;
    --diagram-text: #e2e8f0;
    --diagram-text-muted: #a0aec0;
    --diagram-primary: #7fb3ff;
    --diagram-secondary: #68d391;
    --diagram-accent: #fbd38d;
    --diagram-danger: #fc8181;
    --diagram-border: #4a5568;
    --diagram-fill: #24253a;
  }
  .ps-ring-label {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .ps-feature-title {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 10px;
    font-weight: 600;
    font-style: italic;
  }
  .ps-feature {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 11px;
    font-weight: 400;
  }
  .ps-chip {
    fill: var(--diagram-fill);
    stroke: var(--diagram-border);
    stroke-width: 1;
  }
  .ps-chip-label {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 11px;
    font-weight: 500;
  }
</style>
