---
/**
 * AI Safety boundary diagram.
 * Shows AI Agent on the left, a shield/boundary labeled "Lexicon Law"
 * containing Contracts, Gates, Architecture Rules, Scoring.
 * Repository on the right. Audit Trail below capturing all AI actions.
 */
---

<figure class="diagram-wrapper" aria-label="AI Safety Boundaries">
  <svg viewBox="0 0 760 420" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="AI safety boundaries: AI agent operates through Lexicon Law boundary containing contracts, gates, architecture rules, and scoring, to reach the repository. Audit trail captures all actions.">
    <defs>
      <marker id="ai-arrow" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
        <path d="M0,0 L10,3.5 L0,7" fill="none" stroke="var(--diagram-border)" stroke-width="1.2" stroke-linejoin="round" />
      </marker>
      <marker id="ai-arrow-pass" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
        <path d="M0,0 L10,3.5 L0,7" fill="none" stroke="var(--diagram-secondary)" stroke-width="1.4" stroke-linejoin="round" />
      </marker>
      <marker id="ai-arrow-fail" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
        <path d="M0,0 L10,3.5 L0,7" fill="none" stroke="var(--diagram-danger)" stroke-width="1.4" stroke-linejoin="round" />
      </marker>
      <marker id="ai-arrow-accent" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
        <path d="M0,0 L10,3.5 L0,7" fill="none" stroke="var(--diagram-accent)" stroke-width="1.2" stroke-linejoin="round" />
      </marker>
      <linearGradient id="ai-boundary-grad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="var(--diagram-accent)" stop-opacity="0.10" />
        <stop offset="100%" stop-color="var(--diagram-accent)" stop-opacity="0.02" />
      </linearGradient>
      <linearGradient id="ai-shield-grad" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="var(--diagram-accent)" stop-opacity="0.18" />
        <stop offset="50%" stop-color="var(--diagram-accent)" stop-opacity="0.06" />
        <stop offset="100%" stop-color="var(--diagram-accent)" stop-opacity="0.18" />
      </linearGradient>
      <filter id="ai-shadow" x="-4%" y="-4%" width="108%" height="108%">
        <feDropShadow dx="0" dy="1" stdDeviation="2" flood-color="var(--diagram-text)" flood-opacity="0.05" />
      </filter>
    </defs>

    <!-- Title -->
    <text x="380" y="22" text-anchor="middle" class="ai-title" fill="var(--diagram-text)">AI SAFETY BOUNDARIES</text>
    <line x1="200" y1="32" x2="560" y2="32" stroke="var(--diagram-border)" stroke-width="0.5" stroke-opacity="0.5" />

    <!-- AI Agent (left side) -->
    <rect x="20" y="100" width="140" height="90" rx="14" class="ai-node ai-agent" filter="url(#ai-shadow)" />
    <text x="90" y="138" text-anchor="middle" class="ai-label-lg" fill="var(--diagram-text)">AI Agent</text>
    <text x="90" y="158" text-anchor="middle" class="ai-sublabel" fill="var(--diagram-text-muted)">Claude Code / LLM</text>

    <!-- Shield boundary -->
    <rect x="210" y="50" width="300" height="290" rx="18" fill="url(#ai-boundary-grad)" stroke="var(--diagram-accent)" stroke-width="2" stroke-opacity="0.5" stroke-dasharray="10,5" />

    <!-- Shield icon (small decorative element) -->
    <path d="M360,58 L360,58" fill="none" />
    <text x="360" y="78" text-anchor="middle" class="ai-boundary-label" fill="var(--diagram-accent)">LEXICON LAW</text>

    <!-- Boundary contents: Contracts -->
    <rect x="232" y="96" width="120" height="50" rx="9" class="ai-node ai-law-node" filter="url(#ai-shadow)" />
    <text x="292" y="118" text-anchor="middle" class="ai-label" fill="var(--diagram-text)">Contracts</text>
    <text x="292" y="134" text-anchor="middle" class="ai-sublabel" fill="var(--diagram-text-muted)">behavioral law</text>

    <!-- Boundary contents: Gates -->
    <rect x="368" y="96" width="120" height="50" rx="9" class="ai-node ai-law-node" filter="url(#ai-shadow)" />
    <text x="428" y="118" text-anchor="middle" class="ai-label" fill="var(--diagram-text)">Gates</text>
    <text x="428" y="134" text-anchor="middle" class="ai-sublabel" fill="var(--diagram-text-muted)">enforcement</text>

    <!-- Boundary contents: Architecture Rules -->
    <rect x="232" y="160" width="120" height="50" rx="9" class="ai-node ai-law-node" filter="url(#ai-shadow)" />
    <text x="292" y="182" text-anchor="middle" class="ai-label" fill="var(--diagram-text)">Architecture</text>
    <text x="292" y="198" text-anchor="middle" class="ai-sublabel" fill="var(--diagram-text-muted)">structural rules</text>

    <!-- Boundary contents: Scoring -->
    <rect x="368" y="160" width="120" height="50" rx="9" class="ai-node ai-law-node" filter="url(#ai-shadow)" />
    <text x="428" y="182" text-anchor="middle" class="ai-label" fill="var(--diagram-text)">Scoring</text>
    <text x="428" y="198" text-anchor="middle" class="ai-sublabel" fill="var(--diagram-text-muted)">health metrics</text>

    <!-- Arrow: AI Agent reads context -->
    <line x1="160" y1="120" x2="230" y2="112" stroke="var(--diagram-border)" stroke-width="1.5" marker-end="url(#ai-arrow)" />
    <text x="185" y="108" class="ai-arrow-text" fill="var(--diagram-text-muted)">reads</text>

    <!-- Arrow: AI Agent proposes -->
    <line x1="160" y1="155" x2="230" y2="175" stroke="var(--diagram-accent)" stroke-width="1.5" marker-end="url(#ai-arrow-accent)" />
    <text x="178" y="175" class="ai-arrow-text" fill="var(--diagram-accent)">proposes</text>

    <!-- Verification outcome: Pass -->
    <rect x="240" y="232" width="110" height="40" rx="8" fill="var(--diagram-fill)" stroke="var(--diagram-secondary)" stroke-width="1.5" stroke-opacity="0.7" filter="url(#ai-shadow)" />
    <text x="295" y="256" text-anchor="middle" class="ai-label" fill="var(--diagram-secondary)">Accept</text>

    <!-- Verification outcome: Fail -->
    <rect x="370" y="232" width="110" height="40" rx="8" fill="var(--diagram-fill)" stroke="var(--diagram-danger)" stroke-width="1.5" stroke-opacity="0.7" filter="url(#ai-shadow)" />
    <text x="425" y="256" text-anchor="middle" class="ai-label" fill="var(--diagram-danger)">Reject</text>

    <!-- Arrow pass to result -->
    <line x1="350" y1="252" x2="548" y2="145" stroke="var(--diagram-secondary)" stroke-width="1.5" marker-end="url(#ai-arrow-pass)" />

    <!-- Arrow fail loops back -->
    <path d="M425,272 Q425,295 200,295 Q160,295 160,210 L160,192" fill="none" stroke="var(--diagram-danger)" stroke-width="1.5" stroke-dasharray="6,3" marker-end="url(#ai-arrow-fail)" />
    <text x="280" y="310" text-anchor="middle" class="ai-sublabel" fill="var(--diagram-danger)">retry with feedback</text>

    <!-- Repository (right side) -->
    <rect x="550" y="100" width="180" height="120" rx="14" class="ai-node ai-repo" filter="url(#ai-shadow)" />
    <text x="640" y="140" text-anchor="middle" class="ai-label-lg" fill="var(--diagram-text)">Repository</text>
    <text x="640" y="160" text-anchor="middle" class="ai-sublabel" fill="var(--diagram-text-muted)">source code</text>
    <text x="640" y="176" text-anchor="middle" class="ai-sublabel" fill="var(--diagram-text-muted)">tests &amp; specs</text>
    <text x="640" y="192" text-anchor="middle" class="ai-sublabel" fill="var(--diagram-text-muted)">artifacts</text>

    <!-- Audit Trail (bottom) -->
    <rect x="200" y="348" width="360" height="56" rx="12" class="ai-node ai-audit" filter="url(#ai-shadow)" />
    <text x="380" y="372" text-anchor="middle" class="ai-label" fill="var(--diagram-text)">Audit Trail</text>
    <text x="380" y="390" text-anchor="middle" class="ai-sublabel" fill="var(--diagram-text-muted)">every AI action recorded with timestamp, actor, outcome</text>

    <!-- Dashed lines to audit -->
    <line x1="295" y1="272" x2="340" y2="346" stroke="var(--diagram-border)" stroke-width="1" stroke-dasharray="4,3" />
    <line x1="425" y1="272" x2="420" y2="346" stroke="var(--diagram-border)" stroke-width="1" stroke-dasharray="4,3" />
    <line x1="640" y1="220" x2="500" y2="346" stroke="var(--diagram-border)" stroke-width="1" stroke-dasharray="4,3" />
  </svg>
</figure>

<style>
  .diagram-wrapper {
    margin: 2rem 0;
    padding: 0;
  }
  .diagram-wrapper svg {
    width: 100%;
    max-width: 760px;
    height: auto;
    margin: 0 auto;
    display: block;
    --diagram-bg: #f8f9fa;
    --diagram-text: #2d3748;
    --diagram-text-muted: #718096;
    --diagram-primary: #4a90d9;
    --diagram-secondary: #48bb78;
    --diagram-accent: #ed8936;
    --diagram-danger: #e53e3e;
    --diagram-border: #cbd5e1;
    --diagram-fill: #ffffff;
  }
  :global([data-theme='dark']) .diagram-wrapper svg,
  :global(.sl-theme-dark) .diagram-wrapper svg {
    --diagram-bg: #1a1b26;
    --diagram-text: #e2e8f0;
    --diagram-text-muted: #a0aec0;
    --diagram-primary: #7fb3ff;
    --diagram-secondary: #68d391;
    --diagram-accent: #fbd38d;
    --diagram-danger: #fc8181;
    --diagram-border: #4a5568;
    --diagram-fill: #24253a;
  }
  .ai-node {
    fill: var(--diagram-fill);
    stroke: var(--diagram-border);
    stroke-width: 1.5;
  }
  .ai-agent { stroke: var(--diagram-primary); stroke-width: 2; }
  .ai-law-node { stroke: var(--diagram-accent); stroke-opacity: 0.5; }
  .ai-repo { stroke: var(--diagram-primary); stroke-opacity: 0.5; }
  .ai-audit { stroke: var(--diagram-border); stroke-dasharray: 6,3; }
  .ai-title {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
  }
  .ai-boundary-label {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .ai-label-lg {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 14px;
    font-weight: 700;
  }
  .ai-label {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 12px;
    font-weight: 600;
  }
  .ai-sublabel {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 10px;
    font-weight: 400;
  }
  .ai-arrow-text {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 9.5px;
    font-weight: 500;
    font-style: italic;
  }
</style>
