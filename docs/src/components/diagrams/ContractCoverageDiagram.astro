---
/**
 * Contract coverage diagram.
 * Shows how contract clauses map to tests and where coverage gaps exist.
 */
---

<figure class="diagram-wrapper">
  <svg viewBox="0 0 720 320" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Contract coverage: mapping contract clauses to test tags, showing covered and missing clauses">
    <defs>
      <marker id="cc-arrow" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
        <path d="M0,0 L8,3 L0,6" fill="none" stroke="var(--diagram-arrow)" stroke-width="1.2" />
      </marker>
      <marker id="cc-arrow-green" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
        <path d="M0,0 L8,3 L0,6" fill="none" stroke="#22c55e" stroke-width="1.2" />
      </marker>
    </defs>

    <!-- Contract box (left) -->
    <rect x="20" y="30" width="220" height="260" rx="12" fill="var(--diagram-node-bg)" stroke="#6366f1" stroke-width="1.5" stroke-opacity="0.5" />
    <text x="130" y="56" text-anchor="middle" class="cc-section-label" fill="#6366f1">CONTRACT CLAUSES</text>

    <!-- Clause items -->
    <rect x="36" y="72" width="188" height="32" rx="6" class="cc-clause cc-covered" />
    <text x="130" y="92" text-anchor="middle" class="cc-clause-text" fill="var(--diagram-text)">inv-001: value retrievable</text>

    <rect x="36" y="112" width="188" height="32" rx="6" class="cc-clause cc-covered" />
    <text x="130" y="132" text-anchor="middle" class="cc-clause-text" fill="var(--diagram-text)">req-001: missing key → None</text>

    <rect x="36" y="152" width="188" height="32" rx="6" class="cc-clause cc-covered" />
    <text x="130" y="172" text-anchor="middle" class="cc-clause-text" fill="var(--diagram-text)">req-002: delete idempotent</text>

    <rect x="36" y="192" width="188" height="32" rx="6" class="cc-clause cc-missing" />
    <text x="130" y="212" text-anchor="middle" class="cc-clause-text" fill="var(--diagram-text)">req-003: concurrent writes</text>

    <rect x="36" y="232" width="188" height="32" rx="6" class="cc-clause cc-missing" />
    <text x="130" y="252" text-anchor="middle" class="cc-clause-text" fill="var(--diagram-text)">edge-001: large keys</text>

    <!-- Test box (right) -->
    <rect x="400" y="30" width="300" height="200" rx="12" fill="var(--diagram-node-bg)" stroke="#22c55e" stroke-width="1.5" stroke-opacity="0.5" />
    <text x="550" y="56" text-anchor="middle" class="cc-section-label" fill="#22c55e">CONFORMANCE TESTS</text>

    <!-- Test items -->
    <rect x="416" y="72" width="268" height="32" rx="6" class="cc-test" />
    <text x="550" y="92" text-anchor="middle" class="cc-clause-text" fill="var(--diagram-text)">test inv_get_after_set [conformance.value_retrieval]</text>

    <rect x="416" y="112" width="268" height="32" rx="6" class="cc-test" />
    <text x="550" y="132" text-anchor="middle" class="cc-clause-text" fill="var(--diagram-text)">test req_missing_key [conformance.missing_key]</text>

    <rect x="416" y="152" width="268" height="32" rx="6" class="cc-test" />
    <text x="550" y="172" text-anchor="middle" class="cc-clause-text" fill="var(--diagram-text)">test req_delete_idempotent [conformance.delete]</text>

    <!-- Connecting lines (covered) -->
    <line x1="224" y1="88" x2="414" y2="88" stroke="#22c55e" stroke-width="1.5" stroke-opacity="0.6" marker-end="url(#cc-arrow-green)" />
    <line x1="224" y1="128" x2="414" y2="128" stroke="#22c55e" stroke-width="1.5" stroke-opacity="0.6" marker-end="url(#cc-arrow-green)" />
    <line x1="224" y1="168" x2="414" y2="168" stroke="#22c55e" stroke-width="1.5" stroke-opacity="0.6" marker-end="url(#cc-arrow-green)" />

    <!-- Missing clause indicators -->
    <text x="300" y="210" text-anchor="middle" class="cc-missing-label" fill="#ef4444">no test</text>
    <line x1="224" y1="208" x2="270" y2="208" stroke="#ef4444" stroke-width="1" stroke-dasharray="4,3" />
    <text x="300" y="250" text-anchor="middle" class="cc-missing-label" fill="#ef4444">no test</text>
    <line x1="224" y1="248" x2="270" y2="248" stroke="#ef4444" stroke-width="1" stroke-dasharray="4,3" />

    <!-- Coverage report box (bottom right) -->
    <rect x="400" y="252" width="300" height="56" rx="10" fill="var(--diagram-node-bg)" stroke="var(--diagram-node-border)" stroke-width="1.5" />
    <text x="416" y="273" class="cc-report-label" fill="var(--diagram-text-muted)">COVERAGE REPORT</text>
    <text x="416" y="294" class="cc-report-value" fill="var(--diagram-text)">3 / 5 clauses covered</text>
    <text x="620" y="294" text-anchor="middle" class="cc-report-pct" fill="#f59e0b">60%</text>

    <!-- Coverage bar -->
    <rect x="570" y="264" width="120" height="8" rx="4" fill="var(--diagram-border)" fill-opacity="0.3" />
    <rect x="570" y="264" width="72" height="8" rx="4" fill="#f59e0b" fill-opacity="0.7" />
  </svg>
</figure>

<style>
  .diagram-wrapper {
    margin: 2rem 0;
    padding: 0;
  }
  .diagram-wrapper svg {
    width: 100%;
    max-width: 720px;
    height: auto;
    margin: 0 auto;
    display: block;
    --diagram-text: var(--sl-color-text, #1e293b);
    --diagram-text-muted: var(--sl-color-text-accent, #64748b);
    --diagram-border: var(--sl-color-gray-4, #cbd5e1);
    --diagram-arrow: var(--sl-color-gray-4, #94a3b8);
    --diagram-node-bg: var(--sl-color-bg-nav, #ffffff);
    --diagram-node-border: var(--sl-color-gray-4, #e2e8f0);
  }
  :global([data-theme='dark']) .diagram-wrapper svg,
  :global(.sl-theme-dark) .diagram-wrapper svg {
    --diagram-text: var(--sl-color-text, #e2e8f0);
    --diagram-text-muted: var(--sl-color-text-accent, #94a3b8);
    --diagram-border: var(--sl-color-gray-5, #475569);
    --diagram-arrow: var(--sl-color-gray-5, #64748b);
    --diagram-node-bg: var(--sl-color-bg-nav, #1e293b);
    --diagram-node-border: var(--sl-color-gray-5, #334155);
  }
  .cc-section-label {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .cc-clause {
    stroke-width: 1.5;
  }
  .cc-covered {
    fill: var(--diagram-node-bg);
    stroke: #22c55e;
    stroke-opacity: 0.4;
  }
  .cc-missing {
    fill: var(--diagram-node-bg);
    stroke: #ef4444;
    stroke-opacity: 0.4;
    stroke-dasharray: 4,3;
  }
  .cc-test {
    fill: var(--diagram-node-bg);
    stroke: var(--diagram-node-border);
    stroke-width: 1;
  }
  .cc-clause-text {
    font-family: var(--sl-font-mono, monospace);
    font-size: 9.5px;
    font-weight: 400;
  }
  .cc-missing-label {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 10px;
    font-weight: 500;
    font-style: italic;
  }
  .cc-report-label {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .cc-report-value {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 12px;
    font-weight: 500;
  }
  .cc-report-pct {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 16px;
    font-weight: 700;
  }
</style>
