---
/**
 * Verification pipeline diagram.
 * Horizontal flow: Contracts -> Conformance Tests -> Coverage Analysis ->
 * API Validation -> Gates -> Scoring -> Verification Result
 */
---

<figure class="diagram-wrapper" aria-label="Verification Pipeline">
  <svg viewBox="0 0 760 220" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Verification pipeline: contracts flow through conformance, coverage, API validation, gates, scoring, to a verification result">
    <defs>
      <marker id="vp-arrow" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
        <path d="M0,0 L10,3.5 L0,7" fill="none" stroke="var(--diagram-border)" stroke-width="1.2" stroke-linejoin="round" />
      </marker>
      <marker id="vp-arrow-result" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
        <path d="M0,0 L10,3.5 L0,7" fill="none" stroke="var(--diagram-secondary)" stroke-width="1.4" stroke-linejoin="round" />
      </marker>
      <linearGradient id="vp-result-grad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="var(--diagram-secondary)" stop-opacity="0.22" />
        <stop offset="100%" stop-color="var(--diagram-secondary)" stop-opacity="0.06" />
      </linearGradient>
      <filter id="vp-shadow" x="-4%" y="-4%" width="108%" height="108%">
        <feDropShadow dx="0" dy="1" stdDeviation="2" flood-color="var(--diagram-text)" flood-opacity="0.05" />
      </filter>
    </defs>

    <!-- Title -->
    <text x="380" y="22" text-anchor="middle" class="vp-title" fill="var(--diagram-text-muted)">VERIFICATION PIPELINE</text>
    <line x1="140" y1="32" x2="620" y2="32" stroke="var(--diagram-border)" stroke-width="0.5" stroke-opacity="0.4" stroke-dasharray="4,4" />

    <!-- Stage 1: Contracts -->
    <rect x="12" y="60" width="88" height="88" rx="12" class="vp-node vp-node-primary" filter="url(#vp-shadow)" />
    <text x="56" y="98" text-anchor="middle" class="vp-label" fill="var(--diagram-text)">Contracts</text>
    <text x="56" y="116" text-anchor="middle" class="vp-sublabel" fill="var(--diagram-text-muted)">define</text>
    <line x1="100" y1="104" x2="116" y2="104" stroke="var(--diagram-border)" stroke-width="1.5" marker-end="url(#vp-arrow)" />

    <!-- Stage 2: Conformance Tests -->
    <rect x="118" y="60" width="88" height="88" rx="12" class="vp-node vp-node-primary" filter="url(#vp-shadow)" />
    <text x="162" y="93" text-anchor="middle" class="vp-label" fill="var(--diagram-text)">Confor-</text>
    <text x="162" y="108" text-anchor="middle" class="vp-label" fill="var(--diagram-text)">mance</text>
    <text x="162" y="126" text-anchor="middle" class="vp-sublabel" fill="var(--diagram-text-muted)">prove</text>
    <line x1="206" y1="104" x2="222" y2="104" stroke="var(--diagram-border)" stroke-width="1.5" marker-end="url(#vp-arrow)" />

    <!-- Stage 3: Coverage Analysis -->
    <rect x="224" y="60" width="88" height="88" rx="12" class="vp-node vp-node-primary" filter="url(#vp-shadow)" />
    <text x="268" y="98" text-anchor="middle" class="vp-label" fill="var(--diagram-text)">Coverage</text>
    <text x="268" y="116" text-anchor="middle" class="vp-sublabel" fill="var(--diagram-text-muted)">measure</text>
    <line x1="312" y1="104" x2="328" y2="104" stroke="var(--diagram-border)" stroke-width="1.5" marker-end="url(#vp-arrow)" />

    <!-- Stage 4: API Validation -->
    <rect x="330" y="60" width="88" height="88" rx="12" class="vp-node vp-node-accent" filter="url(#vp-shadow)" />
    <text x="374" y="93" text-anchor="middle" class="vp-label" fill="var(--diagram-text)">API</text>
    <text x="374" y="108" text-anchor="middle" class="vp-label" fill="var(--diagram-text)">Validation</text>
    <text x="374" y="126" text-anchor="middle" class="vp-sublabel" fill="var(--diagram-text-muted)">drift check</text>
    <line x1="418" y1="104" x2="434" y2="104" stroke="var(--diagram-border)" stroke-width="1.5" marker-end="url(#vp-arrow)" />

    <!-- Stage 5: Gates -->
    <rect x="436" y="60" width="88" height="88" rx="12" class="vp-node vp-node-accent" filter="url(#vp-shadow)" />
    <text x="480" y="98" text-anchor="middle" class="vp-label" fill="var(--diagram-text)">Gates</text>
    <text x="480" y="116" text-anchor="middle" class="vp-sublabel" fill="var(--diagram-text-muted)">enforce</text>
    <line x1="524" y1="104" x2="540" y2="104" stroke="var(--diagram-border)" stroke-width="1.5" marker-end="url(#vp-arrow)" />

    <!-- Stage 6: Scoring -->
    <rect x="542" y="60" width="88" height="88" rx="12" class="vp-node vp-node-secondary" filter="url(#vp-shadow)" />
    <text x="586" y="98" text-anchor="middle" class="vp-label" fill="var(--diagram-text)">Scoring</text>
    <text x="586" y="116" text-anchor="middle" class="vp-sublabel" fill="var(--diagram-text-muted)">evaluate</text>
    <line x1="630" y1="104" x2="650" y2="104" stroke="var(--diagram-secondary)" stroke-width="2" marker-end="url(#vp-arrow-result)" />

    <!-- Stage 7: Verification Result -->
    <rect x="652" y="50" width="100" height="108" rx="14" fill="url(#vp-result-grad)" stroke="var(--diagram-secondary)" stroke-width="2" stroke-opacity="0.7" filter="url(#vp-shadow)" />
    <text x="702" y="90" text-anchor="middle" class="vp-label-result" fill="var(--diagram-text)">Verdict</text>
    <text x="702" y="110" text-anchor="middle" class="vp-sublabel" fill="var(--diagram-text-muted)">Pass / Warn / Fail</text>
    <text x="702" y="130" text-anchor="middle" class="vp-sublabel" fill="var(--diagram-text-muted)">+ Audit Record</text>

    <!-- Bottom annotation -->
    <text x="380" y="196" text-anchor="middle" class="vp-cmd" fill="var(--diagram-text-muted)">lexicon verify</text>
  </svg>
</figure>

<style>
  .diagram-wrapper {
    margin: 2rem 0;
    padding: 0;
  }
  .diagram-wrapper svg {
    width: 100%;
    max-width: 760px;
    height: auto;
    margin: 0 auto;
    display: block;
    --diagram-bg: #f8f9fa;
    --diagram-text: #2d3748;
    --diagram-text-muted: #718096;
    --diagram-primary: #4a90d9;
    --diagram-secondary: #48bb78;
    --diagram-accent: #ed8936;
    --diagram-danger: #e53e3e;
    --diagram-border: #cbd5e1;
    --diagram-fill: #ffffff;
  }
  :global([data-theme='dark']) .diagram-wrapper svg,
  :global(.sl-theme-dark) .diagram-wrapper svg {
    --diagram-bg: #1a1b26;
    --diagram-text: #e2e8f0;
    --diagram-text-muted: #a0aec0;
    --diagram-primary: #7fb3ff;
    --diagram-secondary: #68d391;
    --diagram-accent: #fbd38d;
    --diagram-danger: #fc8181;
    --diagram-border: #4a5568;
    --diagram-fill: #24253a;
  }
  .vp-node {
    fill: var(--diagram-fill);
    stroke: var(--diagram-border);
    stroke-width: 1.5;
  }
  .vp-node-primary { stroke: var(--diagram-primary); stroke-opacity: 0.7; }
  .vp-node-accent { stroke: var(--diagram-accent); stroke-opacity: 0.7; }
  .vp-node-secondary { stroke: var(--diagram-secondary); stroke-opacity: 0.7; }
  .vp-label {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 12px;
    font-weight: 600;
  }
  .vp-label-result {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 14px;
    font-weight: 700;
  }
  .vp-sublabel {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 10px;
    font-weight: 400;
  }
  .vp-title {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .vp-cmd {
    font-family: var(--sl-font-mono, monospace);
    font-size: 11px;
    font-weight: 500;
  }
</style>
