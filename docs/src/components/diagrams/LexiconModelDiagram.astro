---
/**
 * The canonical Lexicon model diagram.
 * Hub-spoke layout: Contracts at center, connected to Conformance, Behavior,
 * API Surface, Coverage. These flow into Gates and Scoring, which produce
 * a Verification Result. AI Context reads from contracts/rules.
 */
---

<figure class="diagram-wrapper" aria-label="The Lexicon Model">
  <svg viewBox="0 0 760 520" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="The Lexicon Model: contracts at center connected to conformance, behavior, API surface, coverage, flowing into gates, scoring, and verification result">
    <defs>
      <linearGradient id="lm-core-grad" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="var(--diagram-primary)" stop-opacity="0.18" />
        <stop offset="100%" stop-color="var(--diagram-primary)" stop-opacity="0.04" />
      </linearGradient>
      <linearGradient id="lm-mid-grad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="var(--diagram-secondary)" stop-opacity="0.12" />
        <stop offset="100%" stop-color="var(--diagram-secondary)" stop-opacity="0.03" />
      </linearGradient>
      <linearGradient id="lm-result-grad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="var(--diagram-secondary)" stop-opacity="0.22" />
        <stop offset="100%" stop-color="var(--diagram-secondary)" stop-opacity="0.06" />
      </linearGradient>
      <filter id="lm-shadow" x="-4%" y="-4%" width="108%" height="108%">
        <feDropShadow dx="0" dy="1" stdDeviation="2" flood-color="var(--diagram-text)" flood-opacity="0.06" />
      </filter>
      <marker id="lm-arrow" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
        <path d="M0,0 L10,3.5 L0,7" fill="none" stroke="var(--diagram-border)" stroke-width="1.2" stroke-linejoin="round" />
      </marker>
      <marker id="lm-arrow-accent" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
        <path d="M0,0 L10,3.5 L0,7" fill="none" stroke="var(--diagram-accent)" stroke-width="1.2" stroke-linejoin="round" />
      </marker>
      <marker id="lm-arrow-sec" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
        <path d="M0,0 L10,3.5 L0,7" fill="none" stroke="var(--diagram-secondary)" stroke-width="1.2" stroke-linejoin="round" />
      </marker>
    </defs>

    <!-- Background layer label -->
    <text x="380" y="22" text-anchor="middle" class="lm-title" fill="var(--diagram-text)">THE LEXICON MODEL</text>
    <line x1="180" y1="32" x2="580" y2="32" stroke="var(--diagram-border)" stroke-width="0.5" stroke-opacity="0.5" />

    <!-- Hub region (subtle background) -->
    <rect x="120" y="100" width="520" height="240" rx="16" fill="url(#lm-core-grad)" stroke="var(--diagram-primary)" stroke-width="1" stroke-opacity="0.2" />
    <text x="380" y="120" text-anchor="middle" class="lm-region-label" fill="var(--diagram-primary)">CORE SPECIFICATION</text>

    <!-- Center hub: Contracts -->
    <rect x="290" y="170" width="180" height="72" rx="12" class="lm-node lm-hub" filter="url(#lm-shadow)" />
    <text x="380" y="200" text-anchor="middle" class="lm-label-lg" fill="var(--diagram-text)">Contracts</text>
    <text x="380" y="220" text-anchor="middle" class="lm-sublabel" fill="var(--diagram-text-muted)">the behavioral law</text>

    <!-- Spoke: Conformance (top-right) -->
    <rect x="530" y="130" width="140" height="60" rx="10" class="lm-node lm-spoke" filter="url(#lm-shadow)" />
    <text x="600" y="156" text-anchor="middle" class="lm-label" fill="var(--diagram-text)">Conformance</text>
    <text x="600" y="172" text-anchor="middle" class="lm-sublabel" fill="var(--diagram-text-muted)">proof of behavior</text>
    <line x1="470" y1="188" x2="528" y2="168" stroke="var(--diagram-border)" stroke-width="1.5" marker-end="url(#lm-arrow)" />

    <!-- Spoke: Behavior (top-left) -->
    <rect x="90" y="130" width="140" height="60" rx="10" class="lm-node lm-spoke" filter="url(#lm-shadow)" />
    <text x="160" y="156" text-anchor="middle" class="lm-label" fill="var(--diagram-text)">Behavior</text>
    <text x="160" y="172" text-anchor="middle" class="lm-sublabel" fill="var(--diagram-text-muted)">scenario testing</text>
    <line x1="290" y1="188" x2="232" y2="168" stroke="var(--diagram-border)" stroke-width="1.5" marker-end="url(#lm-arrow)" />

    <!-- Spoke: API Surface (bottom-left) -->
    <rect x="90" y="260" width="140" height="60" rx="10" class="lm-node lm-spoke" filter="url(#lm-shadow)" />
    <text x="160" y="286" text-anchor="middle" class="lm-label" fill="var(--diagram-text)">API Surface</text>
    <text x="160" y="302" text-anchor="middle" class="lm-sublabel" fill="var(--diagram-text-muted)">public interface</text>
    <line x1="290" y1="224" x2="232" y2="272" stroke="var(--diagram-border)" stroke-width="1.5" marker-end="url(#lm-arrow)" />

    <!-- Spoke: Coverage (bottom-right) -->
    <rect x="530" y="260" width="140" height="60" rx="10" class="lm-node lm-spoke" filter="url(#lm-shadow)" />
    <text x="600" y="286" text-anchor="middle" class="lm-label" fill="var(--diagram-text)">Coverage</text>
    <text x="600" y="302" text-anchor="middle" class="lm-sublabel" fill="var(--diagram-text-muted)">clause verification</text>
    <line x1="470" y1="224" x2="528" y2="272" stroke="var(--diagram-border)" stroke-width="1.5" marker-end="url(#lm-arrow)" />

    <!-- Middle tier region -->
    <rect x="120" y="370" width="360" height="70" rx="12" fill="url(#lm-mid-grad)" stroke="var(--diagram-secondary)" stroke-width="1" stroke-opacity="0.2" />
    <text x="300" y="390" text-anchor="middle" class="lm-region-label" fill="var(--diagram-secondary)">ENFORCEMENT</text>

    <!-- Gates -->
    <rect x="140" y="400" width="130" height="52" rx="10" class="lm-node lm-enforce" filter="url(#lm-shadow)" />
    <text x="205" y="422" text-anchor="middle" class="lm-label" fill="var(--diagram-text)">Gates</text>
    <text x="205" y="438" text-anchor="middle" class="lm-sublabel" fill="var(--diagram-text-muted)">pass/fail enforcement</text>

    <!-- Scoring -->
    <rect x="290" y="400" width="130" height="52" rx="10" class="lm-node lm-enforce" filter="url(#lm-shadow)" />
    <text x="355" y="422" text-anchor="middle" class="lm-label" fill="var(--diagram-text)">Scoring</text>
    <text x="355" y="438" text-anchor="middle" class="lm-sublabel" fill="var(--diagram-text-muted)">health metrics</text>

    <!-- Arrows from core to enforcement -->
    <line x1="320" y1="340" x2="220" y2="398" stroke="var(--diagram-secondary)" stroke-width="1.5" marker-end="url(#lm-arrow-sec)" />
    <line x1="420" y1="340" x2="340" y2="398" stroke="var(--diagram-secondary)" stroke-width="1.5" marker-end="url(#lm-arrow-sec)" />

    <!-- Verification Result -->
    <rect x="520" y="388" width="180" height="72" rx="14" fill="url(#lm-result-grad)" stroke="var(--diagram-secondary)" stroke-width="2" stroke-opacity="0.6" filter="url(#lm-shadow)" />
    <text x="610" y="418" text-anchor="middle" class="lm-label-lg" fill="var(--diagram-text)">Verification</text>
    <text x="610" y="438" text-anchor="middle" class="lm-label-lg" fill="var(--diagram-text)">Result</text>
    <text x="610" y="454" text-anchor="middle" class="lm-sublabel" fill="var(--diagram-text-muted)">pass / warn / fail</text>

    <!-- Arrows from gates/scoring to result -->
    <line x1="270" y1="426" x2="518" y2="424" stroke="var(--diagram-secondary)" stroke-width="1.5" marker-end="url(#lm-arrow-sec)" />
    <line x1="420" y1="426" x2="518" y2="424" stroke="var(--diagram-secondary)" stroke-width="1.5" marker-end="url(#lm-arrow-sec)" />

    <!-- AI Context (separate, reads from contracts) -->
    <rect x="90" y="400" width="0" height="0" rx="0" fill="none" />
    <rect x="20" y="50" width="150" height="60" rx="10" class="lm-node lm-ai" filter="url(#lm-shadow)" />
    <text x="95" y="74" text-anchor="middle" class="lm-label" fill="var(--diagram-text)">AI Context</text>
    <text x="95" y="92" text-anchor="middle" class="lm-sublabel" fill="var(--diagram-text-muted)">agent boundaries</text>

    <!-- Dashed arrow from AI Context to Contracts -->
    <path d="M170,80 Q230,80 280,140 Q310,160 310,170" fill="none" stroke="var(--diagram-accent)" stroke-width="1.5" stroke-dasharray="6,4" marker-end="url(#lm-arrow-accent)" />
    <text x="215" y="105" class="lm-arrow-text" fill="var(--diagram-accent)">reads</text>
  </svg>
</figure>

<style>
  .diagram-wrapper {
    margin: 2rem 0;
    padding: 0;
  }
  .diagram-wrapper svg {
    width: 100%;
    max-width: 760px;
    height: auto;
    margin: 0 auto;
    display: block;
    --diagram-bg: #f8f9fa;
    --diagram-text: #2d3748;
    --diagram-text-muted: #718096;
    --diagram-primary: #4a90d9;
    --diagram-secondary: #48bb78;
    --diagram-accent: #ed8936;
    --diagram-danger: #e53e3e;
    --diagram-border: #cbd5e1;
    --diagram-fill: #ffffff;
  }
  :global([data-theme='dark']) .diagram-wrapper svg,
  :global(.sl-theme-dark) .diagram-wrapper svg {
    --diagram-bg: #1a1b26;
    --diagram-text: #e2e8f0;
    --diagram-text-muted: #a0aec0;
    --diagram-primary: #7fb3ff;
    --diagram-secondary: #68d391;
    --diagram-accent: #fbd38d;
    --diagram-danger: #fc8181;
    --diagram-border: #4a5568;
    --diagram-fill: #24253a;
  }
  .lm-node {
    fill: var(--diagram-fill);
    stroke: var(--diagram-border);
    stroke-width: 1.5;
  }
  .lm-hub {
    stroke: var(--diagram-primary);
    stroke-width: 2;
  }
  .lm-spoke {
    stroke: var(--diagram-primary);
    stroke-opacity: 0.6;
  }
  .lm-enforce {
    stroke: var(--diagram-secondary);
    stroke-opacity: 0.7;
  }
  .lm-ai {
    stroke: var(--diagram-accent);
    stroke-width: 1.5;
    stroke-dasharray: 6,3;
  }
  .lm-title {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
  }
  .lm-region-label {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .lm-label-lg {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 14px;
    font-weight: 700;
  }
  .lm-label {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 12.5px;
    font-weight: 600;
  }
  .lm-sublabel {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 10px;
    font-weight: 400;
  }
  .lm-arrow-text {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 10px;
    font-weight: 500;
    font-style: italic;
  }
</style>
